---
import Layout from "./Layout.astro";
import RelatedGuides from "../components/RelatedGuides.astro";

const {
  title,
  description,
  cluster = "",
  canonicalPath,
} = Astro.props;

const resolvedCanonicalPath = canonicalPath ?? Astro.url?.pathname ?? "/";

const SERVICE_MAP = {
  "after-builders": {
    title: "After Builders Cleaning",
    url: "/services/after-builders-cleaning",
    text:
      "After builders cleaning removes plaster dust, cement residue and construction debris left behind after renovation or building work. Professional equipment is used to safely remove fine construction particles and restore the property to a clean, liveable condition."
  },

  "end-of-tenancy": {
    title: "End Of Tenancy Cleaning",
    url: "/services/end-of-tenancy-cleaning",
    text:
      "End of tenancy cleaning prepares rental properties for landlord inspections and inventory checks. Professional tenancy cleaning helps tenants avoid deposit deductions by meeting letting agent cleaning standards."
  },

  "deep-cleaning": {
    title: "Deep Cleaning",
    url: "/services/one-off-deep-cleaning",
    text:
      "Deep cleaning removes heavy dirt build-up, grease and neglected contamination throughout a property. It is typically used before moving in, after long tenancies, or when restoring homes to hygienic condition."
  },

  "carpet-cleaning": {
    title: "Carpet & Rug Cleaning",
    url: "/services/carpet-rug-cleaning",
    text:
      "Professional carpet cleaning removes embedded dirt, stains and allergens trapped within carpet fibres. Specialist cleaning equipment restores carpets and improves indoor hygiene."
  }
};

const service = SERVICE_MAP[cluster] || null;
---

<Layout title={title} description={description} canonicalPath={resolvedCanonicalPath}>

<article class="guide-container">

<header class="guide-header">
<h1>{title}</h1>
</header>

<section class="guide-content">
<slot />
</section>

{service && (

<section class="guide-service">

<hr />

<h2>Professional {service.title}</h2>

<p>
{service.text}
</p>

<p>
<a href={service.url}>
View the {service.title} Service
</a>
</p>

</section>

)}

<hr />

<section class="guide-related">

<h3>Related Guides</h3>

<RelatedGuides />

</section>

</article>

</Layout>
