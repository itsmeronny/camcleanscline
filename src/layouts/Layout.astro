---
const { title, description, canonicalPath = "/" } = Astro.props;

const baseUrl = "https://camcleans.co.uk";
const canonical = `${baseUrl}${canonicalPath}`;

const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "CamCleans",
  url: baseUrl,
  description: "Professional cleaning services across the UK including end of tenancy cleaning, deep cleaning, after builders cleaning and carpet cleaning.",
  areaServed: "United Kingdom"
};

const schemaJson = JSON.stringify(schema);
---

<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />

<meta name="google-site-verification" content="pAsatR2k1X-eVnAENBpTB9Scyy41cSObLsYixLSqxM4" />

<title>{title}</title>

<script type="application/ld+json">
{schemaJson}
</script>

<meta name="description" content={description} />

<link rel="canonical" href={canonical} />

<style>
body {
  margin: 0;
  font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
  line-height: 1.6;
}

header {
  border-bottom: 1px solid #e5e5e5;
  padding: 16px 24px;
  background: #ffffff;
}

nav {
  display: flex;
  gap: 20px;
  align-items: center;
}

nav a {
  text-decoration: none;
  color: #1a1a1a;
  font-weight: 500;
}

nav a:hover {
  text-decoration: underline;
}

.quote-link {
  margin-left: auto;
  background: #1a1a1a;
  color: white;
  padding: 8px 14px;
  border-radius: 6px;
}

.quote-link:hover {
  text-decoration: none;
  opacity: 0.85;
}

main {
  max-width: 900px;
  margin: 40px auto;
  padding: 0 20px;
}

footer {
  margin-top: 60px;
  padding: 30px 20px;
  border-top: 1px solid #e5e5e5;
  font-size: 14px;
  color: #555;
}

.footer-links {
  margin-top: 10px;
  display: flex;
  gap: 18px;
  flex-wrap: wrap;
}

.footer-links a {
  text-decoration: none;
  color: #1a1a1a;
  font-weight: 500;
}

.footer-links a:hover {
  text-decoration: underline;
}
</style>

</head>

<body>

<header>
<nav>
<a href="/">Home</a>
<a href="/services">Services</a>
<a href="/how-camcleans-works">How It Works</a>
<a href="/cleaner-standards">Cleaner Standards</a>
<a href="/cleaning-checklist">Cleaning Checklist</a>
<a href="/contact">Contact</a>

<a class="quote-link" href="/quote">Get a Quote</a>
</nav>
</header>

<main>
<slot />
</main>

<footer>

<p>CamCleans — Professional cleaning services across the United Kingdom.</p>

<div class="footer-links">
<a href="/join-cleaners">Join as a Cleaner</a>
</div>

</footer>

</body>

</html>