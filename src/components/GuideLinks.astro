---
import services from "../data/services";
import locations from "../data/locations";

const { serviceSlug } = Astro.props;

const service = services[serviceSlug];

if (!service) {
  throw new Error("GuideLinks requires a valid serviceSlug");
}

const sampleLocations = Object.values(locations).slice(0, 6);
---

<section>

<h2>{service.name} Services</h2>

<p>
CamCleans provides professional {service.name.toLowerCase()} services across the United Kingdom.
Below are some locations where cleaners are available.
</p>

<ul>

{sampleLocations.map((location) => (

<li>
<a href={`/services/${service.slug}/${location.slug}`}>
{service.name} in {location.name}
</a>
</li>

))}

</ul>

<p>
<a href={`/services/${service.slug}`}>View all {service.name.toLowerCase()} services</a>
</p>

</section>