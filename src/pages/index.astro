---
import Layout from "../layouts/Layout.astro";

const title = "CamCleans | Professional Cleaning Services Across the UK";
const description =
  "Professional cleaning services across the United Kingdom including end of tenancy cleaning, deep cleaning, after builders cleaning and carpet cleaning.";
---

<Layout title={title} description={description} canonicalPath="/">

<style is:global>
/* KEEP YOUR EXISTING CSS EXACTLY AS IS */
</style>

<section class="home-hero">
  <div class="container hero-shell">
    <div class="hero-copy">
      <span class="hero-kicker">UK-wide professional cleaning</span>

      <h1>Book reliable cleaning anywhere in the UK.</h1>

      <p>
        End of tenancy, deep cleaning, after builders and more — 
        clear quotes, proper standards, and cleaners matched to your job.
      </p>

      <div class="hero-actions">
        <a href="/quote" class="btn btn-primary">Get Quote</a>
        <a href="/cleaner-standards" class="btn btn-secondary">Cleaner Standards</a>
      </div>

      <div class="hero-proof">
        <div class="proof">
          <strong>Clear quotes upfront</strong>
          <span>No guesswork</span>
        </div>
        <div class="proof">
          <strong>Matched to your job</strong>
          <span>Right cleaner</span>
        </div>
        <div class="proof">
          <strong>UK-wide coverage</strong>
          <span>National service</span>
        </div>
        <div class="proof">
          <strong>Built for real results</strong>
          <span>Not surface cleaning</span>
        </div>
      </div>
    </div>

    <aside class="hero-panel">
      <span class="panel-eyebrow">Quick quote</span>

      <h2>Get a clear quote, fast.</h2>

      <p>
        Tell us about your property and cleaning requirements. 
        We structure the job properly so you get a clear quote and the right cleaner.
      </p>

      <div class="panel-points">
        <div class="panel-point">
          <div>✓</div>
          <div>
            <b>Clear job structure</b>
            <span>We break down your job properly before quoting.</span>
          </div>
        </div>

        <div class="panel-point">
          <div>✓</div>
          <div>
            <b>Accurate quotes</b>
            <span>Based on property size, condition and requirements.</span>
          </div>
        </div>

        <div class="panel-point">
          <div>✓</div>
          <div>
            <b>Cleaner matching</b>
            <span>Right cleaner for the type of work needed.</span>
          </div>
        </div>
      </div>

      <div class="panel-stats">
        <div class="panel-stat">
          <strong>UK</strong>
          <span>Coverage</span>
        </div>
        <div class="panel-stat">
          <strong>Fast</strong>
          <span>Quotes</span>
        </div>
        <div class="panel-stat">
          <strong>Clear</strong>
          <span>Process</span>
        </div>
      </div>
    </aside>
  </div>
</section>

<section class="proof-strip">
  <div class="container proof-strip-grid">
    <div class="proof-strip-item"><span class="proof-dot"></span><span>Fixed quote before work starts</span></div>
    <div class="proof-strip-item"><span class="proof-dot"></span><span>Cleaners matched to your job</span></div>
    <div class="proof-strip-item"><span class="proof-dot"></span><span>Flexible booking options</span></div>
    <div class="proof-strip-item"><span class="proof-dot"></span><span>UK-wide availability</span></div>
    <div class="proof-strip-item"><span class="proof-dot"></span><span>Built for real cleaning outcomes</span></div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-title">
      <span class="eyebrow">Core services</span>
      <h2>Cleaning services that actually cover real jobs.</h2>
      <p>
        Clear service types designed for real property cleaning requirements.
      </p>
    </div>

    <div class="grid grid-4">
      <article class="card service-card">
        <div class="service-icon">🏠</div>
        <h3>End of Tenancy</h3>
        <p>Cleaning designed to meet landlord and letting standards.</p>
        <a href="/services/end-of-tenancy-cleaning">Explore service →</a>
      </article>

      <article class="card service-card">
        <div class="service-icon">🧱</div>
        <h3>After Builders</h3>
        <p>Removal of dust, debris and residue after building work.</p>
        <a href="/services/after-builders-cleaning">Explore service →</a>
      </article>

      <article class="card service-card">
        <div class="service-icon">✦</div>
        <h3>Deep Cleaning</h3>
        <p>Full property resets for heavily used or neglected homes.</p>
        <a href="/services/deep-cleaning">Explore service →</a>
      </article>

      <article class="card service-card">
        <div class="service-icon">🧼</div>
        <h3>Carpet Cleaning</h3>
        <p>Professional extraction cleaning for improved condition and appearance.</p>
        <a href="/services/carpet-cleaning">Explore service →</a>
      </article>
    </div>
  </div>
</section>

<section class="section operating-section">
  <div class="container">
    <div class="section-title">
      <span class="eyebrow">How it works</span>
      <h2>Simple, clear and structured.</h2>
    </div>

    <div class="grid grid-3">
      <article class="card operating-card">
        <div class="operating-number">1</div>
        <h3>Tell us about your job</h3>
        <p>Provide details about your property and what needs cleaning.</p>
      </article>

      <article class="card operating-card">
        <div class="operating-number">2</div>
        <h3>Get a clear quote</h3>
        <p>We structure the job and give you an accurate quote.</p>
      </article>

      <article class="card operating-card">
        <div class="operating-number">3</div>
        <h3>Book your cleaner</h3>
        <p>Move forward quickly with the right cleaner for your job.</p>
      </article>
    </div>
  </div>
</section>

<section class="section">
  <div class="container enterprise-block">
    <div class="enterprise-left">
      <span class="eyebrow">Standards</span>

      <h3>Cleaning done properly, not rushed.</h3>

      <p>
        Every job is structured before it’s passed to a cleaner. 
        That means clearer expectations, better results, and fewer problems on the day.
      </p>

      <div class="enterprise-points">
        <div class="enterprise-point">
          <div>▣</div>
          <div>
            <b>Clear expectations</b>
            <span>No confusion about what is included.</span>
          </div>
        </div>

        <div class="enterprise-point">
          <div>▣</div>
          <div>
            <b>Proper preparation</b>
            <span>Cleaners arrive ready for the actual job required.</span>
          </div>
        </div>

        <div class="enterprise-point">
          <div>▣</div>
          <div>
            <b>Better outcomes</b>
            <span>Work completed to a higher, more consistent standard.</span>
          </div>
        </div>
      </div>
    </div>

    <div class="enterprise-right">
      <div class="card enterprise-stat">
        <strong>Clear</strong>
        <span>Quotes</span>
        <p>No vague pricing or hidden assumptions.</p>
      </div>

      <div class="card enterprise-stat">
        <strong>Better</strong>
        <span>Matching</span>
        <p>Cleaner suited to the job type.</p>
      </div>

      <div class="card enterprise-stat">
        <strong>Reliable</strong>
        <span>Results</span>
        <p>Work delivered to expected standards.</p>
      </div>
    </div>
  </div>
</section>

<section class="section section-tight">
  <div class="container">
    <div class="section-title">
      <span class="eyebrow">Reviews</span>
      <h2>Clear, straightforward feedback.</h2>
    </div>

    <div class="grid grid-3">
      <article class="card testimonial-card">
        <div class="stars">★★★★★</div>
        <p>
          “Straightforward quote process and no messing around. Much easier than chasing cleaners individually.”
        </p>
      </article>

      <article class="card testimonial-card">
        <div class="stars">★★★★★</div>
        <p>
          “Clearer than most cleaning sites. You actually understand what you're booking.”
        </p>
      </article>

      <article class="card testimonial-card">
        <div class="stars">★★★★★</div>
        <p>
          “Felt more structured and reliable than typical local cleaning companies.”
        </p>
      </article>
    </div>
  </div>
</section>

<section class="section section-tight">
  <div class="container">
    <div class="section-title">
      <span class="eyebrow">FAQs</span>
      <h2>Simple answers.</h2>
    </div>

    <div class="faq-grid">
      <article class="card faq-item">
        <h3>What services do you offer?</h3>
        <p>End of tenancy, deep cleaning, after builders and carpet cleaning across the UK.</p>
      </article>

      <article class="card faq-item">
        <h3>How are quotes calculated?</h3>
        <p>Based on property size, condition and the work required.</p>
      </article>

      <article class="card faq-item">
        <h3>How quickly can I book?</h3>
        <p>Most jobs can be arranged quickly once details are confirmed.</p>
      </article>

      <article class="card faq-item">
        <h3>Do you cover my area?</h3>
        <p>We operate across the United Kingdom.</p>
      </article>
    </div>
  </div>
</section>

<section class="final-cta">
  <div class="container final-cta-shell">
    <div class="final-cta-copy">
      <h2>Get your cleaning quote</h2>

      <p>
        Tell us what needs doing and get a clear, structured quote.
      </p>

      <div class="hero-actions">
        <a href="/quote" class="btn btn-primary">Get Quote</a>
        <a href="/join-cleaners" class="btn btn-secondary">Join Cleaners</a>
      </div>
    </div>

    <div class="final-cta-panel">
      <ul>
        <li><span class="proof-dot"></span><span>Clear quotes</span></li>
        <li><span class="proof-dot"></span><span>Structured jobs</span></li>
        <li><span class="proof-dot"></span><span>Right cleaner matched</span></li>
        <li><span class="proof-dot"></span><span>UK-wide service</span></li>
      </ul>

      <a href="/contact" class="btn btn-dark">Contact CamCleans</a>
    </div>
  </div>
</section>

</Layout>