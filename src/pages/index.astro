---
import Layout from "../layouts/Layout.astro";

const title = "CamCleans | Professional Cleaning Services Across the UK";
const description =
  "Book reliable cleaning anywhere in the UK. End of tenancy, deep cleaning, after builders and carpet cleaning with clear quotes and proper standards.";
---

<Layout title={title} description={description} canonicalPath="/">

<section class="home-hero">
  <div class="container hero-shell">
    <div class="hero-copy">
      <span class="hero-kicker">UK-wide cleaning service</span>

      <h1>Book reliable cleaning anywhere in the UK.</h1>

      <p>
        End of tenancy, deep cleaning, after builders and carpet cleaning —
        clear quotes, proper standards, and cleaners matched to your job.
      </p>

      <div class="hero-actions">
        <a href="/quote" class="btn btn-primary">Get Quote</a>
        <a href="/cleaner-standards" class="btn btn-secondary">Cleaner Standards</a>
      </div>

      <div class="hero-proof">
        <div class="proof">
          <strong>Fixed quotes</strong>
          <span>No surprises</span>
        </div>
        <div class="proof">
          <strong>Right cleaner</strong>
          <span>Matched to job</span>
        </div>
        <div class="proof">
          <strong>Flexible bookings</strong>
          <span>Works around you</span>
        </div>
        <div class="proof">
          <strong>UK-wide</strong>
          <span>Nationwide coverage</span>
        </div>
      </div>
    </div>

    <aside class="hero-panel">
      <span class="panel-eyebrow">Get started</span>

      <h2>Get a clear quote, fast.</h2>

      <p>
        Tell us about your property and cleaning requirements. We structure
        the job properly so you get a clear quote and the right cleaner.
      </p>

      <div class="panel-points">
        <div class="panel-point">
          <div>✓</div>
          <div>
            <b>Clear pricing</b>
            <span>Know what you’re paying before booking</span>
          </div>
        </div>

        <div class="panel-point">
          <div>✓</div>
          <div>
            <b>Proper job matching</b>
            <span>Cleaner suited to your exact job</span>
          </div>
        </div>

        <div class="panel-point">
          <div>✓</div>
          <div>
            <b>Simple process</b>
            <span>No back and forth or confusion</span>
          </div>
        </div>
      </div>

      <div class="panel-stats">
        <div class="panel-stat">
          <strong>UK</strong>
          <span>Coverage</span>
        </div>
        <div class="panel-stat">
          <strong>Fast</strong>
          <span>Quotes</span>
        </div>
        <div class="panel-stat">
          <strong>Clear</strong>
          <span>Pricing</span>
        </div>
      </div>
    </aside>
  </div>
</section>

<section class="proof-strip">
  <div class="container proof-strip-grid">
    <div class="proof-strip-item"><span class="proof-dot"></span><span>Fixed quote before work starts</span></div>
    <div class="proof-strip-item"><span class="proof-dot"></span><span>Cleaner matched to your job</span></div>
    <div class="proof-strip-item"><span class="proof-dot"></span><span>Flexible booking options</span></div>
    <div class="proof-strip-item"><span class="proof-dot"></span><span>UK-wide availability</span></div>
    <div class="proof-strip-item"><span class="proof-dot"></span><span>Built for real cleaning outcomes</span></div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-title">
      <span class="eyebrow">Core services</span>
      <h2>Cleaning services that actually cover real jobs.</h2>
      <p>
        Designed for real-world property cleaning — not generic quick cleans.
      </p>
    </div>

    <div class="grid grid-4">
      <article class="card service-card">
        <div class="service-icon">🏠</div>
        <h3>End of Tenancy</h3>
        <p>Full property clean to meet landlord and letting standards.</p>
        <a href="/services/end-of-tenancy-cleaning">Explore service →</a>
      </article>

      <article class="card service-card">
        <div class="service-icon">🧱</div>
        <h3>After Builders</h3>
        <p>Remove dust, debris and residue after renovation work.</p>
        <a href="/services/after-builders-cleaning">Explore service →</a>
      </article>

      <article class="card service-card">
        <div class="service-icon">✦</div>
        <h3>Deep Cleaning</h3>
        <p>Thorough cleaning for neglected or heavily used properties.</p>
        <a href="/services/deep-cleaning">Explore service →</a>
      </article>

      <article class="card service-card">
        <div class="service-icon">🧼</div>
        <h3>Carpet Cleaning</h3>
        <p>Professional extraction cleaning for carpets and soft flooring.</p>
        <a href="/services/carpet-cleaning">Explore service →</a>
      </article>
    </div>
  </div>
</section>

<section class="section operating-section">
  <div class="container">
    <div class="section-title">
      <span class="eyebrow">How it works</span>
      <h2>Simple, clear and structured.</h2>
    </div>

    <div class="grid grid-3">
      <article class="card operating-card">
        <div class="operating-number">1</div>
        <h3>Tell us about your job</h3>
        <p>Describe the property and what needs cleaning.</p>
      </article>

      <article class="card operating-card">
        <div class="operating-number">2</div>
        <h3>Get a clear quote</h3>
        <p>We structure the job and provide a fixed quote.</p>
      </article>

      <article class="card operating-card">
        <div class="operating-number">3</div>
        <h3>Book your cleaner</h3>
        <p>Cleaner matched and job scheduled to suit you.</p>
      </article>
    </div>
  </div>
</section>

<section class="section">
  <div class="container enterprise-block">
    <div class="enterprise-left">
      <span class="eyebrow">Standards</span>

      <h3>Cleaning done properly, not rushed.</h3>

      <p>
        Every job is structured before it’s passed to a cleaner.
        That means clearer expectations, better results, and fewer problems on the day.
      </p>

      <div class="enterprise-points">
        <div class="enterprise-point">
          <div>▣</div>
          <div>
            <b>Clear scope</b>
            <span>Everyone understands what’s included</span>
          </div>
        </div>

        <div class="enterprise-point">
          <div>▣</div>
          <div>
            <b>Better results</b>
            <span>No missed areas or confusion</span>
          </div>
        </div>

        <div class="enterprise-point">
          <div>▣</div>
          <div>
            <b>Less stress</b>
            <span>Smoother experience from start to finish</span>
          </div>
        </div>
      </div>
    </div>

    <div class="enterprise-right">
      <div class="card enterprise-stat">
        <strong>Clear</strong>
        <span>Quotes</span>
        <p>No hidden pricing or guesswork</p>
      </div>

      <div class="card enterprise-stat">
        <strong>Right</strong>
        <span>Cleaner</span>
        <p>Matched to your specific job</p>
      </div>

      <div class="card enterprise-stat">
        <strong>UK</strong>
        <span>Coverage</span>
        <p>Available across the country</p>
      </div>
    </div>
  </div>
</section>

<section class="section section-tight">
  <div class="container">
    <div class="section-title">
      <span class="eyebrow">Reviews</span>
      <h2>What customers say</h2>
    </div>

    <div class="grid grid-3">
      <article class="card testimonial-card">
        <div class="stars">★★★★★</div>
        <p>“Clear quote and no surprises. Exactly what I needed.”</p>
        <div class="testimonial-person">
          <strong>Tenant</strong>
          <span>End of tenancy</span>
        </div>
      </article>

      <article class="card testimonial-card">
        <div class="stars">★★★★★</div>
        <p>“Cleaner turned up prepared and did a proper job.”</p>
        <div class="testimonial-person">
          <strong>Homeowner</strong>
          <span>Deep cleaning</span>
        </div>
      </article>

      <article class="card testimonial-card">
        <div class="stars">★★★★★</div>
        <p>“Much more structured than other cleaning sites.”</p>
        <div class="testimonial-person">
          <strong>Landlord</strong>
          <span>Property clean</span>
        </div>
      </article>
    </div>
  </div>
</section>

<section class="final-cta">
  <div class="container final-cta-shell">
    <div class="final-cta-copy">
      <h2>Get your cleaning quote</h2>
      <p>Tell us what needs doing and get a clear, structured quote.</p>

      <div class="hero-actions">
        <a href="/quote" class="btn btn-primary">Get Quote</a>
        <a href="/join-cleaners" class="btn btn-secondary">Join Cleaners</a>
      </div>
    </div>

    <div class="final-cta-panel">
      <ul>
        <li><span class="proof-dot"></span><span>Clear pricing</span></li>
        <li><span class="proof-dot"></span><span>Proper job matching</span></li>
        <li><span class="proof-dot"></span><span>Flexible booking</span></li>
        <li><span class="proof-dot"></span><span>Nationwide service</span></li>
      </ul>
    </div>
  </div>
</section>

</Layout>