---
import Layout from "../layouts/Layout.astro";

const title = "CamCleans | Professional Cleaning Services Across the UK";
const description =
  "Professional cleaning services across the United Kingdom including end of tenancy cleaning, deep cleaning, after builders cleaning and carpet cleaning.";
---

<Layout title={title} description={description} canonicalPath="/">

<style is:global>
.home-hero{
  position:relative;
  overflow:hidden;
  padding:44px 0 28px;
  background:
    radial-gradient(circle at top left, rgba(37,99,235,0.12), transparent 28%),
    linear-gradient(180deg, #f8fbff 0%, #edf5ff 100%);
}

.home-hero::before{
  content:"";
  position:absolute;
  inset:auto -120px 40px auto;
  width:420px;
  height:420px;
  border-radius:50%;
  background:radial-gradient(circle, rgba(20,184,166,0.12), transparent 62%);
  pointer-events:none;
}

.hero-shell{
  position:relative;
  display:grid;
  grid-template-columns:minmax(0,1.15fr) minmax(360px,.85fr);
  gap:28px;
  align-items:stretch;
}

.hero-copy{
  padding:34px 0 14px;
}

.hero-kicker{
  display:inline-flex;
  align-items:center;
  gap:10px;
  padding:9px 14px;
  border-radius:999px;
  background:#e8f0ff;
  color:#1d4ed8;
  font-size:13px;
  font-weight:800;
  letter-spacing:.04em;
  text-transform:uppercase;
}

.hero-copy h1{
  margin-top:20px;
  max-width:760px;
  font-family:"Manrope","Inter",sans-serif;
  color:#0f172a;
  font-size:clamp(3rem,5.6vw,5.3rem);
  line-height:.94;
  letter-spacing:-0.06em;
}

.hero-copy p{
  max-width:670px;
  margin-top:20px;
  font-size:19px;
  color:#475569;
}

.hero-actions{
  display:flex;
  flex-wrap:wrap;
  gap:14px;
  margin-top:28px;
}

.hero-proof{
  display:grid;
  grid-template-columns:repeat(4,minmax(0,1fr));
  gap:14px;
  margin-top:34px;
}

.hero-proof .proof{
  padding:16px 18px;
  border-radius:18px;
  background:rgba(255,255,255,0.8);
  border:1px solid #dbe7f5;
  box-shadow:0 10px 30px rgba(15,23,42,0.06);
}

.hero-proof .proof strong{
  display:block;
  font-size:14px;
  line-height:1.25;
  color:#0f172a;
}

.hero-proof .proof span{
  display:block;
  margin-top:6px;
  font-size:12px;
  font-weight:700;
  letter-spacing:.04em;
  text-transform:uppercase;
  color:#2563eb;
}

.hero-panel{
  align-self:start;
  background:linear-gradient(180deg, #ffffff 0%, #f7faff 100%);
  border:1px solid #dbe7f5;
  border-radius:28px;
  box-shadow:0 24px 60px rgba(15,23,42,0.12);
  padding:28px;
}

.hero-panel .panel-eyebrow{
  display:inline-flex;
  align-items:center;
  gap:8px;
  padding:7px 12px;
  border-radius:999px;
  background:#dff7f4;
  color:#0f766e;
  font-size:12px;
  font-weight:800;
  letter-spacing:.04em;
  text-transform:uppercase;
}

.hero-panel h2{
  margin-top:16px;
  font-family:"Manrope","Inter",sans-serif;
  color:#0f172a;
  font-size:34px;
  line-height:1;
  letter-spacing:-0.04em;
}

.hero-panel p{
  margin-top:12px;
  color:#475569;
  font-size:16px;
}

.panel-points{
  display:grid;
  gap:12px;
  margin-top:24px;
}

.panel-point{
  display:flex;
  gap:12px;
  align-items:flex-start;
  padding:14px 16px;
  border-radius:18px;
  background:#fff;
  border:1px solid #e2ebf5;
}

.panel-point b{
  display:block;
  color:#0f172a;
  font-size:15px;
}

.panel-point span{
  display:block;
  color:#64748b;
  font-size:13px;
  margin-top:2px;
}

.panel-stats{
  display:grid;
  grid-template-columns:repeat(3,minmax(0,1fr));
  gap:12px;
  margin-top:20px;
}

.panel-stat{
  padding:16px 14px;
  border-radius:18px;
  background:#0f172a;
  color:#fff;
}

.panel-stat strong{
  display:block;
  font-family:"Manrope","Inter",sans-serif;
  font-size:24px;
  line-height:1;
  letter-spacing:-0.04em;
}

.panel-stat span{
  display:block;
  margin-top:7px;
  font-size:12px;
  color:rgba(255,255,255,0.72);
  font-weight:700;
  text-transform:uppercase;
  letter-spacing:.05em;
}

.proof-strip{
  background:#fff;
  border-top:1px solid #dbe7f5;
  border-bottom:1px solid #dbe7f5;
}

.proof-strip-grid{
  display:grid;
  grid-template-columns:repeat(5,minmax(0,1fr));
  gap:18px;
  padding:22px 0;
}

.proof-strip-item{
  display:flex;
  gap:12px;
  align-items:flex-start;
  color:#334155;
  font-size:14px;
  font-weight:700;
}

.proof-dot{
  width:10px;
  height:10px;
  border-radius:50%;
  background:linear-gradient(135deg,#2563eb 0%,#0f766e 100%);
  flex-shrink:0;
  margin-top:6px;
}

.service-card{
  padding:26px;
}

.service-icon{
  width:54px;
  height:54px;
  display:grid;
  place-items:center;
  border-radius:18px;
  background:linear-gradient(135deg, #dbeafe 0%, #dff7f4 100%);
  color:#0f172a;
  font-size:24px;
}

.service-card h3{
  margin-top:18px;
  font-family:"Manrope","Inter",sans-serif;
  color:#0f172a;
  font-size:24px;
  line-height:1;
  letter-spacing:-0.03em;
}

.service-card p{
  margin-top:14px;
  font-size:15px;
  color:#475569;
}

.service-card a{
  display:inline-flex;
  align-items:center;
  gap:8px;
  margin-top:18px;
  font-weight:800;
  text-decoration:none;
  color:#2563eb;
}

.operating-section{
  background:
    radial-gradient(circle at top right, rgba(37,99,235,0.1), transparent 22%),
    linear-gradient(180deg, #ffffff 0%, #f7faff 100%);
}

.operating-card{
  padding:28px;
}

.operating-number{
  width:40px;
  height:40px;
  display:grid;
  place-items:center;
  border-radius:12px;
  background:#0f172a;
  color:#fff;
  font-weight:800;
}

.operating-card h3{
  margin-top:18px;
  font-family:"Manrope","Inter",sans-serif;
  color:#0f172a;
  font-size:26px;
  line-height:1;
  letter-spacing:-0.03em;
}

.operating-card p{
  margin-top:14px;
  color:#475569;
  font-size:15px;
}

.enterprise-block{
  display:grid;
  grid-template-columns:minmax(0,1fr) minmax(340px,.9fr);
  gap:28px;
  align-items:stretch;
}

.enterprise-left{
  padding:34px;
  background:linear-gradient(180deg, #0f172a 0%, #111c31 100%);
  color:#fff;
  border-radius:28px;
  box-shadow:0 24px 60px rgba(15,23,42,0.18);
}

.enterprise-left .eyebrow{
  background:rgba(255,255,255,0.1);
  color:#93c5fd;
}

.enterprise-left h3{
  margin-top:18px;
  font-family:"Manrope","Inter",sans-serif;
  font-size:42px;
  line-height:.96;
  letter-spacing:-0.05em;
}

.enterprise-left p{
  margin-top:18px;
  color:rgba(255,255,255,0.76);
  font-size:17px;
  max-width:560px;
}

.enterprise-points{
  display:grid;
  gap:14px;
  margin-top:24px;
}

.enterprise-point{
  display:flex;
  gap:12px;
  align-items:flex-start;
  padding:16px 18px;
  border-radius:18px;
  background:rgba(255,255,255,0.06);
  border:1px solid rgba(255,255,255,0.08);
}

.enterprise-point b{
  display:block;
  color:#fff;
  font-size:15px;
}

.enterprise-point span{
  display:block;
  margin-top:3px;
  color:rgba(255,255,255,0.66);
  font-size:13px;
}

.enterprise-right{
  display:grid;
  gap:18px;
}

.enterprise-stat{
  padding:28px;
}

.enterprise-stat strong{
  display:block;
  font-family:"Manrope","Inter",sans-serif;
  color:#0f172a;
  font-size:42px;
  line-height:1;
  letter-spacing:-0.05em;
}

.enterprise-stat span{
  display:block;
  margin-top:10px;
  color:#475569;
  font-size:16px;
  font-weight:700;
}

.enterprise-stat p{
  margin-top:10px;
  color:#64748b;
  font-size:14px;
}

.testimonial-card{
  padding:28px;
}

.stars{
  color:#2563eb;
  font-size:15px;
  letter-spacing:.08em;
}

.testimonial-card p{
  margin-top:16px;
  color:#334155;
  font-size:15px;
}

.testimonial-person{
  margin-top:18px;
}

.testimonial-person strong{
  display:block;
  color:#0f172a;
  font-size:15px;
}

.testimonial-person span{
  display:block;
  color:#64748b;
  font-size:13px;
  margin-top:3px;
}

.faq-grid{
  display:grid;
  grid-template-columns:repeat(2,minmax(0,1fr));
  gap:20px;
}

.faq-item{
  padding:22px 24px;
}

.faq-item h3{
  color:#0f172a;
  font-size:18px;
  font-weight:800;
}

.faq-item p{
  margin-top:10px;
  color:#475569;
  font-size:15px;
}

.final-cta{
  padding:82px 0;
  background:
    radial-gradient(circle at top right, rgba(20,184,166,0.16), transparent 22%),
    linear-gradient(180deg, #0f172a 0%, #111c31 100%);
}

.final-cta-shell{
  display:grid;
  grid-template-columns:minmax(0,1.1fr) minmax(320px,.9fr);
  gap:24px;
  align-items:center;
}

.final-cta-copy h2{
  font-family:"Manrope","Inter",sans-serif;
  color:#fff;
  font-size:clamp(2.2rem,4vw,4rem);
  line-height:.95;
  letter-spacing:-0.05em;
}

.final-cta-copy p{
  margin-top:16px;
  color:rgba(255,255,255,0.72);
  font-size:18px;
  max-width:640px;
}

.final-cta-panel{
  padding:28px;
  border-radius:26px;
  background:rgba(255,255,255,0.06);
  border:1px solid rgba(255,255,255,0.1);
  color:#fff;
}

.final-cta-panel ul{
  list-style:none;
  display:grid;
  gap:12px;
  margin:0;
  padding:0;
}

.final-cta-panel li{
  display:flex;
  gap:12px;
  align-items:flex-start;
  color:rgba(255,255,255,0.82);
  font-size:15px;
}

.final-cta-panel .btn{
  margin-top:22px;
}

@media (max-width:1100px){
  .hero-shell,
  .enterprise-block,
  .final-cta-shell{
    grid-template-columns:1fr;
  }

  .hero-proof,
  .proof-strip-grid{
    grid-template-columns:repeat(2,minmax(0,1fr));
  }
}

@media (max-width:820px){
  .panel-stats,
  .faq-grid{
    grid-template-columns:1fr;
  }
}

@media (max-width:640px){
  .home-hero{
    padding-top:30px;
  }

  .hero-shell{
    gap:20px;
  }

  .hero-proof,
  .proof-strip-grid{
    grid-template-columns:1fr;
  }

  .hero-copy h1{
    font-size:clamp(2.5rem,12vw,3.6rem);
  }
}
</style>

<section class="home-hero">
  <div class="container hero-shell">
    <div class="hero-copy">
      <span class="hero-kicker">UK-wide professional cleaning quotes</span>
      <h1>Book reliable cleaning anywhere in the UK.</h1>
      <p>
        End of tenancy, deep cleaning, after builders and carpet cleaning —
        clear quotes, proper standards, and cleaners matched to your job.
      </p>

      <div class="hero-actions">
        <a href="/quote" class="btn btn-primary">Get a Quote</a>
        <a href="/cleaner-standards" class="btn btn-secondary">See Cleaner Standards</a>
      </div>

      <div class="hero-proof">
        <div class="proof">
          <strong>Clear quotes upfront</strong>
          <span>No guesswork</span>
        </div>
        <div class="proof">
          <strong>Matched to your job</strong>
          <span>Right cleaner</span>
        </div>
        <div class="proof">
          <strong>UK-wide coverage</strong>
          <span>National service</span>
        </div>
        <div class="proof">
          <strong>Built for real results</strong>
          <span>Not surface cleaning</span>
        </div>
      </div>
    </div>

    <aside class="hero-panel">
      <span class="panel-eyebrow">How it works</span>
      <h2>Get a clear quote, fast.</h2>
      <p>
        Tell us about your property and cleaning requirements.
        We structure the job properly so you get a clear quote and the right cleaner.
      </p>

      <div class="panel-points">
        <div class="panel-point">
          <div>✓</div>
          <div>
            <b>Submit the job once</b>
            <span>Property type, service and job details are captured clearly from the start.</span>
          </div>
        </div>

        <div class="panel-point">
          <div>✓</div>
          <div>
            <b>Get a structured quote</b>
            <span>No vague back and forth before the job is even understood.</span>
          </div>
        </div>

        <div class="panel-point">
          <div>✓</div>
          <div>
            <b>Cleaner matched to the work</b>
            <span>The job is routed based on service type, scope and availability.</span>
          </div>
        </div>
      </div>

      <div class="panel-stats">
        <div class="panel-stat">
          <strong>UK</strong>
          <span>Coverage</span>
        </div>
        <div class="panel-stat">
          <strong>Fast</strong>
          <span>Quotes</span>
        </div>
        <div class="panel-stat">
          <strong>Clear</strong>
          <span>Process</span>
        </div>
      </div>
    </aside>
  </div>
</section>

<section class="proof-strip">
  <div class="container proof-strip-grid">
    <div class="proof-strip-item"><span class="proof-dot"></span><span>Fixed quote before work starts</span></div>
    <div class="proof-strip-item"><span class="proof-dot"></span><span>Cleaners matched to your job</span></div>
    <div class="proof-strip-item"><span class="proof-dot"></span><span>Flexible booking options</span></div>
    <div class="proof-strip-item"><span class="proof-dot"></span><span>UK-wide availability</span></div>
    <div class="proof-strip-item"><span class="proof-dot"></span><span>Built for real cleaning outcomes</span></div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-title">
      <span class="eyebrow">Core services</span>
      <h2>Cleaning services that actually cover real jobs.</h2>
      <p>
        Four core services built around the jobs people actually need done properly.
      </p>
    </div>

    <div class="grid grid-4">
      <article class="card service-card">
        <div class="service-icon">🏠</div>
        <h3>End of Tenancy</h3>
        <p>Cleaning for move-out inspections, landlord expectations and property handover standards.</p>
        <a href="/services/end-of-tenancy-cleaning">Explore service →</a>
      </article>

      <article class="card service-card">
        <div class="service-icon">🧱</div>
        <h3>After Builders</h3>
        <p>Post-renovation cleaning for dust, residue and getting the property ready to use again.</p>
        <a href="/services/after-builders-cleaning">Explore service →</a>
      </article>

      <article class="card service-card">
        <div class="service-icon">✦</div>
        <h3>Deep Cleaning</h3>
        <p>Whole-property cleaning for resets, neglected homes, move-ins and one-off intensive jobs.</p>
        <a href="/services/deep-cleaning">Explore service →</a>
      </article>

      <article class="card service-card">
        <div class="service-icon">🧼</div>
        <h3>Carpet Cleaning</h3>
        <p>Professional carpet cleaning for stains, odours, heavy use areas and tenancy-related standards.</p>
        <a href="/services/carpet-cleaning">Explore service →</a>
      </article>
    </div>
  </div>
</section>

<section class="section operating-section">
  <div class="container">
    <div class="section-title">
      <span class="eyebrow">How it works</span>
      <h2>Simple from first quote to completed job.</h2>
      <p>
        CamCleans is built to make booking clearer, faster and less messy than chasing cleaners one by one.
      </p>
    </div>

    <div class="grid grid-3">
      <article class="card operating-card">
        <div class="operating-number">1</div>
        <h3>Tell us about your job</h3>
        <p>Choose the service, add your property details and tell us what needs doing.</p>
      </article>

      <article class="card operating-card">
        <div class="operating-number">2</div>
        <h3>Get a clear quote</h3>
        <p>Your enquiry is structured properly so the scope is understood before work is arranged.</p>
      </article>

      <article class="card operating-card">
        <div class="operating-number">3</div>
        <h3>Book the right cleaner</h3>
        <p>The job is matched based on service type, scope and availability.</p>
      </article>
    </div>
  </div>
</section>

<section class="section">
  <div class="container enterprise-block">
    <div class="enterprise-left">
      <span class="eyebrow">Professional standards</span>
      <h3>Cleaning done properly, not rushed.</h3>
      <p>
        Every job is structured before it is passed to a cleaner.
        That means clearer expectations, better results and fewer problems on the day.
      </p>

      <div class="enterprise-points">
        <div class="enterprise-point">
          <div>▣</div>
          <div>
            <b>Clearer job information</b>
            <span>Property details and service requirements are captured before the work is arranged.</span>
          </div>
        </div>

        <div class="enterprise-point">
          <div>▣</div>
          <div>
            <b>Better fit for the job</b>
            <span>Cleaning requirements are matched to the service needed, not treated like a generic booking.</span>
          </div>
        </div>

        <div class="enterprise-point">
          <div>▣</div>
          <div>
            <b>Stronger outcomes</b>
            <span>The goal is a properly understood job with fewer surprises, delays and misunderstandings.</span>
          </div>
        </div>
      </div>
    </div>

    <div class="enterprise-right">
      <div class="card enterprise-stat">
        <strong>Clear</strong>
        <span>Quote process</span>
        <p>Structured input means less confusion before the job is booked.</p>
      </div>

      <div class="card enterprise-stat">
        <strong>Reliable</strong>
        <span>Job matching</span>
        <p>Each enquiry is routed based on the actual work required.</p>
      </div>

      <div class="card enterprise-stat">
        <strong>UK-wide</strong>
        <span>Coverage</span>
        <p>A national service built around real cleaning demand across the country.</p>
      </div>
    </div>
  </div>
</section>

<section class="section section-tight">
  <div class="container">
    <div class="section-title">
      <span class="eyebrow">Why customers use CamCleans</span>
      <h2>Built for jobs where the result matters.</h2>
      <p>
        CamCleans is designed for cleaning requests that need to be understood properly before work starts.
      </p>
    </div>

    <div class="grid grid-3">
      <article class="card testimonial-card">
        <div class="stars">★★★★★</div>
        <p>
          End of tenancy cleaning where deposit protection, inspections and handover standards matter.
        </p>
        <div class="testimonial-person">
          <strong>Move-out jobs</strong>
          <span>Tenancy and landlord-focused cleaning</span>
        </div>
      </article>

      <article class="card testimonial-card">
        <div class="stars">★★★★★</div>
        <p>
          Deep cleaning for homes that need more than a light tidy-up or standard recurring clean.
        </p>
        <div class="testimonial-person">
          <strong>One-off resets</strong>
          <span>Heavy domestic cleaning</span>
        </div>
      </article>

      <article class="card testimonial-card">
        <div class="stars">★★★★★</div>
        <p>
          After builders and specialist jobs where dust, residue and presentation need to be dealt with properly.
        </p>
        <div class="testimonial-person">
          <strong>Property-ready finishes</strong>
          <span>Post-build and handover cleaning</span>
        </div>
      </article>
    </div>
  </div>
</section>

<section class="section section-tight">
  <div class="container">
    <div class="section-title">
      <span class="eyebrow">Frequently asked</span>
      <h2>Clean answers. No fluff.</h2>
    </div>

    <div class="faq-grid">
      <article class="card faq-item">
        <h3>What makes CamCleans different?</h3>
        <p>It gives you a clearer route to quote and a cleaner matched to the actual job, instead of a vague enquiry process.</p>
      </article>

      <article class="card faq-item">
        <h3>What services can I book?</h3>
        <p>CamCleans currently focuses on end of tenancy cleaning, deep cleaning, after builders cleaning and carpet cleaning.</p>
      </article>

      <article class="card faq-item">
        <h3>How do quotes work?</h3>
        <p>You submit the property and job details through a structured form so the work can be understood properly before booking.</p>
      </article>

      <article class="card faq-item">
        <h3>Can cleaners join the network?</h3>
        <p>Yes. Professional cleaners can apply to join the CamCleans network through the cleaner application page.</p>
      </article>
    </div>
  </div>
</section>

<section class="final-cta">
  <div class="container final-cta-shell">
    <div class="final-cta-copy">
      <h2>Get your cleaning quote</h2>
      <p>
        Tell us what needs doing and get a clear, structured quote for your job.
      </p>
      <div class="hero-actions">
        <a href="/quote" class="btn btn-primary">Get a Quote</a>
        <a href="/join-cleaners" class="btn btn-secondary">Join Cleaners</a>
      </div>
    </div>

    <div class="final-cta-panel">
      <ul>
        <li><span class="proof-dot"></span><span>Clear quote process from the start</span></li>
        <li><span class="proof-dot"></span><span>Core services built around real cleaning jobs</span></li>
        <li><span class="proof-dot"></span><span>Cleaner matching based on the work required</span></li>
