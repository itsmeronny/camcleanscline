---
import GuideLayout from "../../layouts/GuideLayout.astro";

const title = "End of Tenancy Cleaning Checklist (UK)";
const description =
  "Room-by-room checklist used when preparing a rental property for landlord inspection at the end of a tenancy.";

const canonical = "/guides/end-of-tenancy-cleaning-kitchen-appliance-standard";
---

<GuideLayout title={title} description={description} canonicalPath={canonical}>

<section>
<h1>End of Tenancy Cleaning Checklist</h1>
<p>End of tenancy cleaning prepares a rental property for landlord inspection and helps avoid deposit deductions.</p>
</section>

<section>
<h2>Kitchen</h2>
<ul>
<li>Clean cupboards inside and out</li>
<li>Degrease hob and extractor</li>
<li>Clean oven interior</li>
<li>Sanitise worktops</li>
<li>Wipe appliances</li>
</ul>
</section>

<section>
<h2>Bathroom</h2>
<ul>
<li>Descale shower and tiles</li>
<li>Clean toilet and sink</li>
<li>Remove limescale</li>
<li>Clean mirrors and cabinets</li>
</ul>
</section>

<section>
<h2>Living Areas</h2>
<ul>
<li>Dust surfaces</li>
<li>Clean skirting boards</li>
<li>Vacuum carpets</li>
<li>Clean windows</li>
</ul>
</section>

<section>
<h2>Professional Service</h2>
<p><a href="/services/end-of-tenancy-cleaning">End of Tenancy Cleaning Service</a></p>
</section>

</Layout>

