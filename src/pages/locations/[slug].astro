---
import services from "../../data/services";
import locations from "../../data/locations";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  return Object.values(locations).map((location) => ({
    params: { slug: location.slug },
  }));
}

const { slug } = Astro.params;
const location = locations[slug];

if (!location) {
  throw new Error("Location not found");
}
---

<Layout
  title={`Cleaning Services in ${location.name} | CamCleans`}
  description={`Professional cleaning services available across ${location.name}.`}
  canonicalPath={`/locations/${location.slug}`}
>

<section>
<h1>Cleaning Services in {location.name}</h1>

<p>
CamCleans coordinates structured cleaning services throughout {location.name}.
Services are delivered using checklist-driven cleaning standards designed for
reliability and inspection-ready results.
</p>
</section>

<section>
<h2>Available Services in {location.name}</h2>

<ul>
{Object.values(services).map((service) => (
<li>
<a href={`/services/${service.slug}/${location.slug}`}>
{service.name} in {location.name}
</a>
</li>
))}
</ul>

</section>

<section>

<h2>Property Types Covered</h2>

<ul>
<li>Apartments</li>
<li>Houses</li>
<li>Rental properties</li>
<li>Renovation projects</li>
<li>Commercial offices</li>
</ul>

</section>

</Layout>