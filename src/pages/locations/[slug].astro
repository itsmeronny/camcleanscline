---
import Layout from "../../layouts/Layout.astro";
import services from "../../data/services";
import locations from "../../data/locations";
import BreadcrumbJsonLd from "../../components/seo/BreadcrumbJsonLd.astro";

export async function getStaticPaths() {
  return Object.keys(locations).map((slug) => ({
    params: { slug }
  }));
}

const { slug } = Astro.params;
const location = locations[slug];

if (!location) throw new Error("Location not found");

const canonicalPath = `/locations/${slug}`;
const title = `Cleaning Services in ${location.name} | CamCleans`;
const description = `Professional cleaning services available in ${location.name}. Structured scope, consistent standards, and email-based booking.`;
---

<Layout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
>

  <BreadcrumbJsonLd
    items={[
      { name: "Home", path: "/" },
      { name: "Locations", path: "/locations" },
      { name: location.name, path: canonicalPath }
    ]}
  />

  <main>

    <h1>Cleaning Services in {location.name}</h1>

    <p>
      CamCleans provides structured cleaning services throughout {location.name}.
      Each service follows clearly defined inclusions and checklist standards
      to ensure consistency and clarity.
    </p>

    <h2>Available Services in {location.name}</h2>

    <ul>
      {Object.keys(services).map((serviceSlug) => (
        <li>
          <a href={`/services/${serviceSlug}/${slug}`}>
            {services[serviceSlug].name} in {location.name}
          </a>
        </li>
      ))}
    </ul>

    <h2>Service Standards</h2>

    <p>
      All services in {location.name} follow structured scopes rather than
      informal cleaning arrangements. This ensures expectations remain aligned
      before work begins.
    </p>

  </main>

</Layout>