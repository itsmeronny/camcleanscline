---
import Layout from "../layouts/Layout.astro";

const title = "Contact CamCleans | Cleaning Enquiries Across the United Kingdom";
const description =
  "Submit a cleaning enquiry to CamCleans for end of tenancy cleaning, deep cleaning or after builders cleaning across the United Kingdom.";
---

<Layout title={title} description={description} canonicalPath="/contact">

<section class="section">
<div class="container">

<div class="section-title">
<span class="eyebrow">Enquiry</span>
<h2>Contact CamCleans</h2>
<p>
Submit a cleaning enquiry using the form below. CamCleans connects households,
landlords and property professionals with independent cleaners operating across the United Kingdom.
</p>
</div>

<div class="card" style="padding:40px;max-width:760px;margin:0 auto;">

<form action="/contact-enquiry" method="POST" enctype="application/x-www-form-urlencoded">

<div class="grid grid-2">

<div>
<label>Name</label>
<input type="text" name="name" required style="width:100%;margin-top:6px;padding:12px;border:1px solid var(--line);border-radius:10px;">
</div>

<div>
<label>Email</label>
<input type="email" name="email" required style="width:100%;margin-top:6px;padding:12px;border:1px solid var(--line);border-radius:10px;">
</div>

<div>
<label>Phone</label>
<input type="tel" name="phone" style="width:100%;margin-top:6px;padding:12px;border:1px solid var(--line);border-radius:10px;">
</div>

<div>
<label>Postcode</label>
<input type="text" name="postcode" required style="width:100%;margin-top:6px;padding:12px;border:1px solid var(--line);border-radius:10px;">
</div>

</div>

<div style="margin-top:20px;">
<label>Service required</label>
<select name="service" style="width:100%;margin-top:6px;padding:12px;border:1px solid var(--line);border-radius:10px;">
<option value="">Select service</option>
<option>End of tenancy cleaning</option>
<option>Deep cleaning</option>
<option>After builders cleaning</option>
<option>Carpet cleaning</option>
<option>Commercial cleaning</option>
<option>Airbnb cleaning</option>
</select>
</div>

<div style="margin-top:20px;">
<label>Cleaning details</label>
<textarea name="message" rows="6" required style="width:100%;margin-top:6px;padding:12px;border:1px solid var(--line);border-radius:10px;"></textarea>
</div>

<div style="margin-top:28px;text-align:center;">
<button class="btn btn-primary" type="submit">
Send cleaning enquiry
</button>
</div>

</form>

</div>

</div>
</section>


<section class="section section-tight">
<div class="container">

<div class="section-title">
<span class="eyebrow">Information</span>
<h2>Cleaning enquiries across the United Kingdom</h2>
<p>
CamCleans supports enquiries for several types of professional cleaning services including end of tenancy cleaning,
deep cleaning and after builders cleaning.
</p>
</div>

<div class="grid grid-3">

<div class="card">
<h3>Residential cleaning enquiries</h3>
<p>
Cleaning services for homes, apartments and rental properties.
</p>
</div>

<div class="card">
<h3>Landlord and letting enquiries</h3>
<p>
Inspection ready cleaning before tenant move in or property handover.
</p>
</div>

<div class="card">
<h3>Renovation cleaning</h3>
<p>
Removal of dust and debris following renovation or building work.
</p>
</div>

</div>

</div>
</section>

</Layout>