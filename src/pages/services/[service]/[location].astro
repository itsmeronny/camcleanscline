---
import services from "../../../data/services";
import locations from "../../../data/locations";
import Layout from "../../../layouts/Layout.astro";
import BreadcrumbJsonLd from "../../../components/seo/BreadcrumbJsonLd.astro";
import ServiceJsonLd from "../../../components/seo/ServiceJsonLd.astro";
import LocalBusinessJsonLd from "../../../components/seo/LocalBusinessJsonLd.astro";

export async function getStaticPaths() {
  const paths = [];
  for (const serviceSlug of Object.keys(services)) {
    for (const locationSlug of Object.keys(locations)) {
      paths.push({
        params: {
          service: serviceSlug,
          location: locationSlug,
        },
      });
    }
  }
  return paths;
}

const { service: serviceSlug, location: locationSlug } = Astro.params;

const service = services[serviceSlug];
const location = locations[locationSlug];

if (!service || !location) {
  throw new Error("Invalid service or location");
}

const canonicalPath = `/services/${serviceSlug}/${locationSlug}`;
const title = `${service.name} in ${location.name} | CamCleans`;
const description = `${service.short} Available in ${location.name}. Structured scope and consistent cleaning standards.`;

/* ---------- MARKET CLASSIFICATION ---------- */

const renovationHeavyCities = [
  "london",
  "manchester",
  "birmingham",
  "bristol"
];

const isAfterBuilders = serviceSlug === "after-builders-cleaning";
const isRenovationCity = renovationHeavyCities.includes(locationSlug);

/* ---------- RELATED SERVICE LOGIC ---------- */

const relatedMap = {
  "after-builders-cleaning": [
    "one-off-deep-cleaning",
    "office-cleaning",
    "end-of-tenancy-cleaning"
  ],
  "end-of-tenancy-cleaning": [
    "oven-cleaning",
    "carpet-rug-cleaning",
    "appliances-cleaning"
  ],
  "airbnb-cleaning": [
    "housekeeper-cleaner",
    "linen-cleaning",
    "one-off-deep-cleaning"
  ],
  "one-off-deep-cleaning": [
    "after-builders-cleaning",
    "carpet-rug-cleaning",
    "sofa-upholstery-cleaning"
  ]
};

const relatedServices = relatedMap[serviceSlug] || [];
---

<Layout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
>

  <BreadcrumbJsonLd
    items={[
      { name: "Home", path: "/" },
      { name: "Services", path: "/services" },
      { name: service.name, path: `/services/${serviceSlug}` },
      { name: location.name, path: canonicalPath }
    ]}
  />

  <ServiceJsonLd
    serviceName={`${service.name} in ${location.name}`}
    description={description}
    url={`https://camcleans.co.uk${canonicalPath}`}
  />

  <LocalBusinessJsonLd
    serviceName={service.name}
    locationName={location.name}
    url={`https://camcleans.co.uk${canonicalPath}`}
  />

  <h1>{service.name} in {location.name}</h1>

  <p>
    CamCleans provides structured {service.name.toLowerCase()} services
    throughout {location.name}. All services operate with defined scope,
    checklist alignment, and consistent execution standards.
  </p>

  {isAfterBuilders && isRenovationCity && (
    <>
      <h2>Post-Construction Activity in {location.name}</h2>
      <p>
        {location.name} experiences consistent renovation and refurbishment
        cycles. After builders cleaning ensures properties are
        inspection-ready and presentation-complete following project completion.
      </p>
    </>
  )}

  <h2>What This Service Covers in {location.name}</h2>
  <ul>
    {service.inclusions.map((item) => <li>{item}</li>)}
  </ul>

  <h2>Who Books This Service in {location.name}</h2>
  <ul>
    {service.idealFor.map((item) => <li>{item}</li>)}
  </ul>

  {/* STRUCTURAL AUTHORITY LINKS */}

  <h2>Explore Related Services in {location.name}</h2>
  <ul>
    <li>
      <a href={`/services/${serviceSlug}`}>
        View {service.name} Service Overview
      </a>
    </li>
    <li>
      <a href={`/locations/${locationSlug}`}>
        All Cleaning Services in {location.name}
      </a>
    </li>

    {relatedServices.map((related) =>
      services[related] ? (
        <li>
          <a href={`/services/${related}/${locationSlug}`}>
            {services[related].name} in {location.name}
          </a>
        </li>
      ) : null
    )}
  </ul>

  <h2>Book {service.name} in {location.name}</h2>
  <ul>
    {service.cta.bullets.map((b) => <li>{b}</li>)}
  </ul>

  <a href={service.cta.buttonHref}>
    {service.cta.buttonText}
  </a>

</Layout>