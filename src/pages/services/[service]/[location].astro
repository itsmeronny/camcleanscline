---
import services from "../../../data/services";
import locations from "../../../data/locations";
import Layout from "../../../layouts/Layout.astro";
import BreadcrumbJsonLd from "../../../components/seo/BreadcrumbJsonLd.astro";
import ServiceJsonLd from "../../../components/seo/ServiceJsonLd.astro";
import LocalBusinessJsonLd from "../../../components/seo/LocalBusinessJsonLd.astro";

export async function getStaticPaths() {
  const paths = [];
  for (const serviceSlug of Object.keys(services)) {
    for (const locationSlug of Object.keys(locations)) {
      paths.push({
        params: {
          service: serviceSlug,
          location: locationSlug,
        },
      });
    }
  }
  return paths;
}

const { service: serviceSlug, location: locationSlug } = Astro.params;

const service = services[serviceSlug];
const location = locations[locationSlug];

if (!service || !location) {
  throw new Error("Invalid service or location");
}

const canonicalPath = `/services/${serviceSlug}/${locationSlug}`;
const title = `${service.name} in ${location.name} | CamCleans`;
const description = `${service.short} Available in ${location.name}. Structured scope and consistent cleaning standards.`;

/* ---------- MARKET CLASSIFICATION ---------- */

const majorCities = [
  "london",
  "manchester",
  "birmingham",
  "glasgow",
  "edinburgh"
];

const renovationHeavyCities = [
  "london",
  "manchester",
  "birmingham",
  "bristol"
];

const isEOT = serviceSlug === "end-of-tenancy-cleaning";
const isAirbnb = serviceSlug === "airbnb-cleaning";
const isDeepClean = serviceSlug === "one-off-deep-cleaning";
const isAfterBuilders = serviceSlug === "after-builders-cleaning";

const isMajorCity = majorCities.includes(locationSlug);
const isRenovationCity = renovationHeavyCities.includes(locationSlug);
---

<Layout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
>

  <BreadcrumbJsonLd
    items={[
      { name: "Home", path: "/" },
      { name: "Services", path: "/services" },
      { name: service.name, path: `/services/${serviceSlug}` },
      { name: location.name, path: canonicalPath }
    ]}
  />

  <ServiceJsonLd
    serviceName={`${service.name} in ${location.name}`}
    description={description}
    url={`https://camcleans.co.uk${canonicalPath}`}
  />

  <LocalBusinessJsonLd
    serviceName={service.name}
    locationName={location.name}
    url={`https://camcleans.co.uk${canonicalPath}`}
  />

  <h1>{service.name} in {location.name}</h1>

  <p>
    CamCleans provides structured {service.name.toLowerCase()} services
    throughout {location.name}. All services operate with defined scope,
    checklist alignment, and consistent execution standards.
  </p>

  {/* AFTER BUILDERS AUTHORITY INSERT */}

  {isAfterBuilders && (
    <>
      <h2>Post-Construction Cleaning in {location.name}</h2>

      <p>
        After builders cleaning supports renovation, refurbishment,
        extension and fit-out projects across {location.name}.
        The service removes fine construction dust, installation residue,
        plaster particles and presentation-impacting contamination
        prior to occupation or inspection.
      </p>

      {isRenovationCity && (
        <>
          <h3>Renovation & Refurbishment Activity</h3>
          <p>
            {location.name} experiences consistent development and
            refurbishment cycles. Post-construction cleaning ensures
            properties are handover-ready for landlords, buyers,
            tenants or commercial occupants.
          </p>
        </>
      )}

      {isMajorCity && (
        <>
          <h3>Developer & Contractor Scheduling</h3>
          <p>
            In larger urban markets such as {location.name},
            phased project completion and tight handover timelines
            require structured scheduling and predictable execution.
          </p>
        </>
      )}

      <h3>Typical Post-Build Areas Addressed</h3>
      <ul>
        <li>Fine plaster dust removal from horizontal surfaces</li>
        <li>Internal glazing and frame detailing</li>
        <li>Skirting board and door frame wipe-down</li>
        <li>Light fitting and socket detailing</li>
        <li>Kitchen and bathroom installation cleaning</li>
        <li>Hard floor vacuuming and mopping</li>
      </ul>

      <h3>Related Post-Project Services</h3>
      <ul>
        <li>
          <a href={`/services/office-cleaning/${locationSlug}`}>
            Office Cleaning in {location.name}
          </a>
        </li>
        <li>
          <a href={`/services/one-off-deep-cleaning/${locationSlug}`}>
            One Off Deep Cleaning in {location.name}
          </a>
        </li>
        <li>
          <a href={`/services/end-of-tenancy-cleaning/${locationSlug}`}>
            End of Tenancy Cleaning in {location.name}
          </a>
        </li>
      </ul>
    </>
  )}

  {/* EXISTING SERVICE-SPECIFIC LOGIC */}

  {isDeepClean && (
    <>
      <h2>What One-Off Deep Cleaning Covers in {location.name}</h2>
      <p>
        One-off deep cleaning focuses on accumulated build-up,
        neglected surfaces, internal doors, skirting boards,
        and detailed kitchen and bathroom restoration.
      </p>
    </>
  )}

  {isEOT && (
    <>
      <h2>Inspection-Focused End of Tenancy Cleaning in {location.name}</h2>
      <p>
        End of tenancy cleaning aligns with inventory-led inspections,
        prioritising deposit-sensitive areas.
      </p>
    </>
  )}

  {isAirbnb && (
    <>
      <h2>Airbnb Turnover Cleaning in {location.name}</h2>
      <p>
        Airbnb cleaning prioritises presentation standards and
        high-touch sanitisation to support guest experience.
      </p>
    </>
  )}

  <h2>What This Service Covers in {location.name}</h2>
  <ul>
    {service.inclusions.map((item) => <li>{item}</li>)}
  </ul>

  <h2>Who Typically Books This Service in {location.name}</h2>
  <ul>
    {service.idealFor.map((item) => <li>{item}</li>)}
  </ul>

  <h2>Related Services in {location.name}</h2>
  <ul>
    {Object.keys(services)
      .filter((s) => s !== serviceSlug)
      .map((s) => (
        <li>
          <a href={`/services/${s}/${locationSlug}`}>
            {services[s].name} in {location.name}
          </a>
        </li>
      ))}
  </ul>

  <h2>Book {service.name} in {location.name}</h2>
  <ul>
    {service.cta.bullets.map((b) => <li>{b}</li>)}
  </ul>

  <a href={service.cta.buttonHref}>
    {service.cta.buttonText}
  </a>

</Layout>