---
import Layout from "../../layouts/Layout.astro";
import GuideLinks from "../../components/GuideLinks.astro";
import services from "../../data/services";

export async function getStaticPaths() {
  return Object.values(services).map((service) => ({
    params: { slug: service.slug },
  }));
}

const { slug } = Astro.params;
const service = services[slug];

if (!service) {
  throw new Error("Service not found");
}
---

<Layout title={service.name} description={service.description}>

<article class="service-container">

<header>
<h1>{service.name}</h1>
</header>

<section>
<p>{service.description}</p>
</section>

<hr />

<section class="service-guides">

<h2>Helpful Cleaning Guides</h2>

<GuideLinks serviceSlug={slug} />

</section>

<hr />

<section class="service-related-services">

<h2>Related Cleaning Services</h2>

<ul>
<li><a href="/services/end-of-tenancy-cleaning/">End of Tenancy Cleaning</a></li>
<li><a href="/services/one-off-deep-cleaning/">Deep Cleaning</a></li>
<li><a href="/services/after-builders-cleaning/">After Builders Cleaning</a></li>
<li><a href="/services/carpet-rug-cleaning/">Carpet & Rug Cleaning</a></li>
</ul>

</section>

</article>

</Layout>