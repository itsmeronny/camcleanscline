---
import Layout from "../../layouts/Layout.astro";
import GuideLinks from "../../components/GuideLinks.astro";
import services from "../../data/services";

export async function getStaticPaths() {
  return Object.values(services).map((service) => ({
    params: { slug: service.slug }
  }));
}

const { slug } = Astro.params;
const service = services[slug];

if (!service) {
  throw new Error("Service not found");
}
---

<Layout title={service.name} description={service.description}>

<article class="service-container">

<header class="service-header">
<h1>{service.name}</h1>
<p>{service.description}</p>
</header>

<section class="service-content">
<p>
Professional {service.name.toLowerCase()} delivered to consistent national
standards. Structured cleaning processes ensure reliable results for homes,
tenancies, renovations and commercial properties.
</p>
</section>

<section class="service-locations">

<h2>Available Locations</h2>

<ul>
{Object.keys(service.locations || {}).map((location) => (
<li>
<a href={`/services/${slug}/${location}`}>
{service.name} in {location}
</a>
</li>
))}
</ul>

</section>

<GuideLinks />

</article>

</Layout>