---
import services from "../../data/services";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  return Object.values(services).map((service) => ({
    params: { slug: service.slug },
  }));
}

const { slug } = Astro.params;
const service = services[slug];

if (!service) {
  throw new Error("Service not found");
}

const isAfterBuilders = slug === "after-builders-cleaning";
---

<Layout
  title={`${service.name} | CamCleans`}
  description={service.short}
  canonicalPath={`/services/${service.slug}`}
>

  <section>
    <h1>{service.name}</h1>
    <p>{service.intro}</p>
  </section>

  <section>
    <h2>What's Included</h2>
    <ul>
      {service.inclusions.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  </section>

  <section>
    <h2>What's Excluded</h2>
    <ul>
      {service.exclusions.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  </section>

  <section>
    <h2>Ideal For</h2>
    <ul>
      {service.idealFor.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  </section>

  {isAfterBuilders && (
    <section>
      <h2>Construction Phase Cleaning Structure</h2>

      <h3>Stage 1: Initial Debris Reset</h3>
      <p>
        Removal of fine plaster dust, installation residue and surface-level build contamination once builders have cleared major waste.
      </p>

      <h3>Stage 2: Detailed Surface Extraction</h3>
      <p>
        Structured extraction of dust from horizontal, vertical and high-level surfaces including frames, fixtures and newly installed units.
      </p>

      <h3>Stage 3: Handover Presentation Finish</h3>
      <p>
        Final polish of internal glazing, skirting, floors and sanitary installations to achieve inspection-ready standards.
      </p>

      <h3>Commercial & Developer Scheduling</h3>
      <p>
        Suitable for phased developments, refurbishment cycles and contractor-led completion schedules.
      </p>
    </section>
  )}

  <section>
    <h2>Service Checklist</h2>
    <ul>
      {service.checklist.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  </section>

  <section>
    <h2>Frequently Asked Questions</h2>
    {service.faqs.map((faq) => (
      <div>
        <h3>{faq.q}</h3>
        <p>{faq.a}</p>
      </div>
    ))}
  </section>

  {isAfterBuilders && (
    <section>
      <h2>After Builders Cleaning Guides</h2>
      <ul>
        <li>
          <a href="/guides/after-builders-dust-removal">
            After Builders Dust Removal Guide
          </a>
        </li>
      </ul>
    </section>
  )}

  <section>
    <h2>{service.cta.heading}</h2>
    <ul>
      {service.cta.bullets.map((b) => (
        <li>{b}</li>
      ))}
    </ul>
    <a href={service.cta.buttonHref}>
      {service.cta.buttonText}
    </a>
  </section>

</Layout>